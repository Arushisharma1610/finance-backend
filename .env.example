# ── Server ────────────────────────────────────────────────
PORT=3000

# ── JWT Auth ──────────────────────────────────────────────
# Change this to any long random string before running
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=7d

# ── PostgreSQL Database ───────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_db
DB_USER=postgres
DB_PASSWORD=your_postgres_password
